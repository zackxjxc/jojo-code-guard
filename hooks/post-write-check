#!/usr/bin/env bash
# 文件工具完成或 AI 回合结束时运行差异检查，并返回对应的 Hook 协议。
set -u

# 先读取一次事件输入，后续同时解析 cwd 和 Stop 重入标记。
HOOK_INPUT="$(cat || true)"

if command -v py >/dev/null 2>&1 && py -3 -c 'import sys' >/dev/null 2>&1; then
    PYTHON=(py -3)
elif command -v python3 >/dev/null 2>&1; then
    PYTHON=(python3)
elif command -v python >/dev/null 2>&1 \
    && python -c 'import sys; raise SystemExit(sys.version_info[0] != 3)' >/dev/null 2>&1; then
    PYTHON=(python)
else
    echo "jojo-code-guard: Python 3 is required for lifecycle checks." >&2
    exit 2
fi

HOOK_EVENT="${1:-}"
if [ -z "$HOOK_EVENT" ]; then
    HOOK_EVENT="$(printf '%s' "$HOOK_INPUT" | PYTHONIOENCODING=utf-8 "${PYTHON[@]}" -c '
import json
import sys

try:
    value = json.load(sys.stdin).get("hook_event_name", "")
except (AttributeError, json.JSONDecodeError, UnicodeDecodeError):
    value = ""
print(value if isinstance(value, str) else "")
' 2>/dev/null || true)"
fi
HOOK_EVENT="${HOOK_EVENT:-PostToolUse}"
if [ "$HOOK_EVENT" != "PostToolUse" ] && [ "$HOOK_EVENT" != "Stop" ]; then
    echo "jojo-code-guard: unsupported hook event: ${HOOK_EVENT}" >&2
    exit 2
fi

plugin_root="${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-}}}"
if [ -n "$plugin_root" ]; then
    PLUGIN_ROOT="$plugin_root"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
# 客户端在 Windows 可能传入反斜杠路径，先转换为 Bash 可识别的形式
PLUGIN_ROOT="${PLUGIN_ROOT//\\\\//}"
CHECK_SCRIPT="${PLUGIN_ROOT}/skills/jojo-code-guard/scripts/check_diff.py"

if [ "$HOOK_EVENT" = "Stop" ]; then
    STOP_HOOK_ACTIVE="$(printf '%s' "$HOOK_INPUT" | PYTHONIOENCODING=utf-8 "${PYTHON[@]}" -c '
import json
import sys

try:
    value = json.load(sys.stdin).get("stop_hook_active", False)
except (AttributeError, json.JSONDecodeError, UnicodeDecodeError):
    value = False
print("true" if value is True else "false")
' 2>/dev/null || printf 'false')"
    if [ "$STOP_HOOK_ACTIVE" = "true" ]; then
        exit 0
    fi
fi

if [ ! -r "$CHECK_SCRIPT" ]; then
    echo "jojo-code-guard: 无法读取差异检查脚本：${CHECK_SCRIPT}" >&2
    exit 2
fi

# 客户端事件中的 cwd 最接近本次工具调用；解析失败时再使用环境变量或进程目录。
INPUT_CWD="$(printf '%s' "$HOOK_INPUT" | PYTHONIOENCODING=utf-8 "${PYTHON[@]}" -c '
import json
import sys

try:
    value = json.load(sys.stdin).get("cwd", "")
except (AttributeError, json.JSONDecodeError, UnicodeDecodeError):
    value = ""
print(value if isinstance(value, str) else "")
' 2>/dev/null || true)"
if [ -n "$INPUT_CWD" ]; then
    PROJECT_ROOT="$INPUT_CWD"
elif [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
    PROJECT_ROOT="$CLAUDE_PROJECT_DIR"
else
    PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi
PROJECT_ROOT="${PROJECT_ROOT//\\\\//}"

emit_empty_result() {
    return 0
}

# 非 Git 目录不属于本守护范围，避免普通文件操作被无意义地阻断。
if [ -z "$PROJECT_ROOT" ]; then
    emit_empty_result
    exit 0
fi
if ! PROJECT_ROOT="$(git -C "$PROJECT_ROOT" rev-parse --show-toplevel 2>/dev/null)"; then
    emit_empty_result
    exit 0
fi

set +e
OUTPUT="$("${PYTHON[@]}" "$CHECK_SCRIPT" --repo "$PROJECT_ROOT" --json 2>&1)"
STATUS=$?
set -e

BLOCKED=false
if [ "$STATUS" -ge 2 ]; then
    BLOCKED=true
    CONTEXT="jojo-code-guard: 差异检查执行失败：
${OUTPUT}"
elif [ -z "$OUTPUT" ]; then
    BLOCKED=true
    CONTEXT="jojo-code-guard: check_diff.py 未返回 JSON 诊断，已按阻断处理。"
elif [ "$OUTPUT" = "[]" ] && [ "$STATUS" -eq 0 ]; then
    emit_empty_result
    exit 0
elif [ "$OUTPUT" = "[]" ] && [ "$STATUS" -eq 1 ]; then
    BLOCKED=true
    CONTEXT="jojo-code-guard: check_diff.py 返回阻断状态但没有诊断，已按阻断处理。"
else
    if [ "$HOOK_EVENT" = "Stop" ]; then
        CONTEXT="$(printf 'jojo-code-guard: AI 回合结束前检查结果：\n%s' "$OUTPUT")"
    else
        CONTEXT="$(printf 'jojo-code-guard: AI 写入后检查结果：\n%s' "$OUTPUT")"
    fi
    if BLOCKED_RESULT="$(
        printf '%s' "$OUTPUT" | "${PYTHON[@]}" -c '
import json
import sys

data = json.load(sys.stdin)
if not isinstance(data, list) or not all(isinstance(item, dict) for item in data):
    raise ValueError("diagnostics must be a JSON array of objects")
print("true" if any(item.get("level") == "BLOCKED" for item in data) else "false")
' 2>/dev/null
    )"; then
        if [ "$STATUS" -eq 1 ] || [ "$BLOCKED_RESULT" = "true" ]; then
            BLOCKED=true
        fi
    else
        BLOCKED=true
        CONTEXT="${CONTEXT}
jojo-code-guard: 检查输出无法解析，已按阻断处理。"
    fi
fi

# Stop 只在阻断时要求继续修复；PostToolUse 会把所有诊断立即反馈给 AI。
if [ "$HOOK_EVENT" = "Stop" ] && [ "$BLOCKED" != "true" ]; then
    exit 0
fi
if ! printf '%s' "$CONTEXT" \
    | JOJO_HOOK_EVENT="$HOOK_EVENT" JOJO_HOOK_BLOCKED="$BLOCKED" PYTHONIOENCODING=utf-8 \
        "${PYTHON[@]}" -c '
import json
import os
import sys

event = os.environ["JOJO_HOOK_EVENT"]
blocked = os.environ.get("JOJO_HOOK_BLOCKED") == "true"
context = sys.stdin.read()
if event == "Stop":
    payload = {
        "continue": True,
        "decision": "block",
        "reason": context + "\n请修复阻断项并重新运行检查后再结束本回合。",
    }
else:
    payload = {
        "continue": True,
        "hookSpecificOutput": {
            "hookEventName": "PostToolUse",
            "additionalContext": context,
        },
    }
    if blocked:
        payload["decision"] = "block"
        payload["reason"] = "写入后检查发现阻断项，请先修复污染再继续"
print(json.dumps(payload, ensure_ascii=False))
'; then
    echo "jojo-code-guard: failed to build structured ${HOOK_EVENT} output." >&2
    exit 2
fi
# 已完成的写入不会被伪装成未执行；阻断反馈会让 AI 根据诊断继续修复。
exit 0
