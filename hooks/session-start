#!/usr/bin/env bash
# 会话入口：注入自动守护规则和当前项目 AGENTS.md。
set -euo pipefail

plugin_root="${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-}}}"
if [ -n "$plugin_root" ]; then
    PLUGIN_ROOT="$plugin_root"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
# 客户端在 Windows 可能传入反斜杠路径，先转换为 Bash 可识别的形式
PLUGIN_ROOT="${PLUGIN_ROOT//\\\\//}"
SKILL_FILE="${PLUGIN_ROOT}/skills/jojo-code-guard/SKILL.md"

if [ ! -r "$SKILL_FILE" ]; then
    load_error="jojo-code-guard: 无法读取 Skill：${SKILL_FILE}"
    load_context="<JOJO_CODE_GUARD_LOAD_FAILED>${load_error}；"
    load_context="${load_context}必须暂停文件修改并向用户报告。</JOJO_CODE_GUARD_LOAD_FAILED>"
    printf '%s\n' "$load_error" >&2
    printf '%s\n' "$load_context"
    exit 0
fi

if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
    project_root="$CLAUDE_PROJECT_DIR"
else
    project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
fi
project_root="${project_root//\\\\//}"
if git_root="$(git -C "$project_root" rev-parse --show-toplevel 2>/dev/null)"; then
    project_root="$git_root"
fi
# 强制守护规则——遵守系统、用户和项目规则的优先级顺序
mandatory_header="【强制守护规则】以下是 jojo-code-guard 的强制工作约束，"
mandatory_header="${mandatory_header}在不违反更高优先级指令的前提下适用于所有任务。"
mandatory_header="${mandatory_header}不得擅自降级为可忽略的参考材料。"

emit_context() {
    printf '%s\n\n<JOJO_CODE_GUARD>\n' "$mandatory_header"
    cat "$SKILL_FILE"
    if [ -f "${project_root}/AGENTS.md" ]; then
        printf '\n\n--- project AGENTS.md ---\n'
        cat "${project_root}/AGENTS.md"
    fi
    printf '\n</JOJO_CODE_GUARD>\n'
}

# Claude 和 Codex 都会把 SessionStart 的普通 stdout 加入模型上下文。
emit_context
