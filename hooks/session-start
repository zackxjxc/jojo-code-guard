#!/usr/bin/env bash
# Claude 会话入口：注入自动守护规则和当前项目 AGENTS.md。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"
SKILL_FILE="${PLUGIN_ROOT}/skills/jojo-code-guard/SKILL.md"

escape_for_json() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    value="${value//$'\r'/\\r}"
    value="${value//$'\t'/\\t}"
    printf '%s' "$value"
}

skill_content=$(cat "$SKILL_FILE" 2>&1 || echo "无法读取 jojo-code-guard Skill")
project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
project_rules=""
if [ -f "${project_root}/AGENTS.md" ]; then
    project_rules=$(printf '\n\n--- project AGENTS.md ---\n'; cat "${project_root}/AGENTS.md")
fi
# 强制守护规则——所有条款均为强制指令，优先级等同于用户全局规则（CLAUDE.md）
mandatory_header="【强制守护规则】以下规则优先级等同于用户全局规则（CLAUDE.md），适用于所有任务、所有时刻。所有条款均为强制指令，不得忽略或降级为参考材料。"
context=$(printf '%s\n\n<JOJO_CODE_GUARD>\n%s%s\n</JOJO_CODE_GUARD>' "$mandatory_header" "$skill_content" "$project_rules")
escaped=$(escape_for_json "$context")
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
