#!/usr/bin/env bash
# Claude 会话入口：注入自动守护规则和当前项目 AGENTS.md。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"
SKILL_FILE="${PLUGIN_ROOT}/skills/jojo-code-guard/SKILL.md"

if [ ! -r "$SKILL_FILE" ]; then
    echo "jojo-code-guard: 无法读取 Skill：${SKILL_FILE}" >&2
    exit 1
fi

project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
# 强制守护规则——所有条款均为强制指令，优先级等同于用户全局规则（CLAUDE.md）
mandatory_header="【强制守护规则】以下规则优先级等同于用户全局规则（CLAUDE.md），适用于所有任务、所有时刻。所有条款均为强制指令，不得忽略或降级为参考材料。"

# SessionStart 的普通标准输出会由 Claude Code 直接加入上下文
printf '%s\n\n<JOJO_CODE_GUARD>\n' "$mandatory_header"
cat "$SKILL_FILE"
if [ -f "${project_root}/AGENTS.md" ]; then
    printf '\n\n--- project AGENTS.md ---\n'
    cat "${project_root}/AGENTS.md"
fi
printf '\n</JOJO_CODE_GUARD>\n'
